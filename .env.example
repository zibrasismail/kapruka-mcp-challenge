# 9Router OpenAI-compatible gateway
# Get your key from 9Router dashboard → Endpoint → API Keys
NINEROUTER_API_KEY=your_9router_api_key_here

# Production proxy (default). For local 9Router use: http://localhost:20128/v1
NINEROUTER_BASE_URL=https://9router.softwareaccess.in/v1

# Primary model + comma-separated fallbacks
AI_MODEL=ag/claude-sonnet-4-6
AI_MODEL_FALLBACKS=ag/claude-opus-4-6-thinking,ag/gemini-3-flash-agent,mimo/mimo-v2.5-pro,groq/llama-3.3-70b-versatile